# ============================================================
# .env.example — copy to .env and fill in your credentials
# ============================================================

# ---- App ----
APP_NAME=AI Resume Screening
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=8501

# ---- Gemini 2.5 Flash ----
# Get key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_TOKENS=8192
GEMINI_TIMEOUT=60
GEMINI_MAX_RETRIES=3

# ---- Airtable ----
# Get key: https://airtable.com/create/tokens
# Get base ID: Airtable > Help > API documentation
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=Candidates

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_ENABLED=true

# ---- Google OAuth (Gmail + Calendar) ----
# Get credentials: https://console.cloud.google.com/apis/credentials
# Enable Gmail API + Google Calendar API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
# Path to credentials.json downloaded from Google Cloud Console
GOOGLE_CREDENTIALS_FILE=
CALENDAR_ID=primary
INTERVIEW_DURATION_MINUTES=60
INTERVIEW_LOOKAHEAD_DAYS=7

# ---- Email ----
SMTP_FROM_EMAIL=recruiter@example.com
SMTP_FROM_NAME=AI Recruiter

# ---- Business Rules ----
SHORTLIST_THRESHOLD=80
REVIEW_THRESHOLD=60

# ---- n8n (Workflow Automation) ----
# n8n receives candidate JSON from FastAPI after AI analysis.
# It handles: Google Calendar, Google Meet, Gmail, Airtable updates.
# Import workflows/n8n_workflow.json into n8n and activate it.
N8N_WEBHOOK_URL=http://localhost:5678/webhook/interview
N8N_API_KEY=

# ---- Security ----
SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=*
